{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Build",
            "type": "shell",
            "command": "__BUILD_SCRIPT__",
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "options": {
                "shell": {
                    "executable": "/bin/bash",
                },
                "cwd": "${workspaceFolder}"
            }
        }
    ]
}