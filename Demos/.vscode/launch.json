{
    "version": "0.2.0",
    "inputs": [
        {
            "id": "demo",
            "type": "pickString",
            "description": "Select demo",
            "options": [
                "screensaver",
                "lightning",
                "raindrops",
                "shooter",
                "gradient"
            ]
        }
    ],
    "configurations": [
        {
            "name": "Run",
            "type": "coreclr",
            "request": "launch",
            "preLaunchTask": "dotnet: build",
            "program": "${workspaceFolder}/bin/Debug/net10.0/TMDemo.dll",
            "args": ["${input:demo}"],
            "console": "externalTerminal"
        }
    ]
}